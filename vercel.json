{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["public/Realmap.jpg"]
      }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/analyze", "dest": "/server.js" },
    { "src": "/generate-map", "dest": "/server.js" },
    { "src": "/scan-data", "dest": "/server.js" },
    { "src": "/groups/(.*)", "dest": "/server.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
